<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/black" android:orientation="vertical">
    <!-- Header with back button -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
        android:padding="16dp" android:background="@color/bg_surface" android:gravity="center_vertical">
        <TextView android:id="@+id/chatBackBtn" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="&lt; BACK" android:textSize="14sp" android:textColor="@color/matrix_green"
            android:fontFamily="monospace" android:paddingEnd="16dp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="&gt; NEURAL CHAT" android:textSize="18sp" android:textColor="@color/matrix_green"
            android:fontFamily="monospace" android:textStyle="bold"/>
        <TextView android:id="@+id/chatStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="[ONLINE]" android:textSize="10sp" android:textColor="@color/matrix_green_dim" android:fontFamily="monospace"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
    <androidx.recyclerview.widget.RecyclerView android:id="@+id/chatRecyclerView" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1" android:padding="12dp" android:clipToPadding="false"/>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
        android:padding="12dp" android:background="@color/bg_surface">
        <EditText android:id="@+id/chatInput" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:hint="> Enter query..." android:textColorHint="@color/text_hint"
            android:textColor="@color/matrix_green" android:background="@color/bg_input" android:padding="14dp"
            android:textSize="14sp" android:fontFamily="monospace" android:inputType="text"
            android:maxLines="1" android:imeOptions="actionSend"/>
        <Button android:id="@+id/chatSendBtn" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text=">" android:textColor="@color/black" android:background="@drawable/bg_btn_primary"
            android:paddingStart="20dp" android:paddingEnd="20dp" android:fontFamily="monospace" android:textSize="18sp"
            android:textStyle="bold" android:minHeight="48dp" android:textAllCaps="false"/>
    </LinearLayout>
</LinearLayout>
