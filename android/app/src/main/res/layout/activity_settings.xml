<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:background="@color/black">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        <!-- Header with back button -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal"
            android:padding="16dp" android:background="@color/bg_surface" android:gravity="center_vertical">
            <TextView android:id="@+id/settingsBackBtn" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="&lt; BACK" android:textSize="14sp" android:textColor="@color/matrix_green"
                android:fontFamily="monospace" android:paddingEnd="16dp"/>
            <TextView android:text="## SYSTEM CONFIG" android:textSize="18sp" android:textColor="@color/matrix_green"
                android:fontFamily="monospace" android:textStyle="bold"/>
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
            <TextView android:text="-- API CONFIGURATION --" android:textSize="11sp" android:textColor="@color/biohazard_red"
                android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.2" android:layout_marginBottom="12dp"/>
            <TextView android:text="Endpoint URL:" android:textSize="11sp" android:textColor="@color/text_hint"
                android:fontFamily="monospace" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/settingsApiUrl" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColorHint="@color/text_hint" android:textColor="@color/matrix_green" android:background="@color/bg_input"
                android:padding="14dp" android:textSize="13sp" android:fontFamily="monospace"
                android:inputType="textUri" android:layout_marginBottom="16dp"/>
            <TextView android:text="Access Key:" android:textSize="11sp" android:textColor="@color/text_hint"
                android:fontFamily="monospace" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/settingsApiKey" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColorHint="@color/text_hint" android:textColor="@color/matrix_green" android:background="@color/bg_input"
                android:padding="14dp" android:textSize="13sp" android:fontFamily="monospace"
                android:inputType="textPassword" android:layout_marginBottom="16dp"/>
            <TextView android:text="Model Designation:" android:textSize="11sp" android:textColor="@color/text_hint"
                android:fontFamily="monospace" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/settingsModel" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColorHint="@color/text_hint" android:textColor="@color/matrix_green" android:background="@color/bg_input"
                android:padding="14dp" android:textSize="13sp" android:fontFamily="monospace"
                android:layout_marginBottom="16dp"/>
            <TextView android:text="System Directive:" android:textSize="11sp" android:textColor="@color/text_hint"
                android:fontFamily="monospace" android:layout_marginBottom="4dp"/>
            <EditText android:id="@+id/settingsSystemPrompt" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textColorHint="@color/text_hint" android:textColor="@color/matrix_green" android:background="@color/bg_input"
                android:padding="14dp" android:textSize="13sp" android:fontFamily="monospace"
                android:inputType="textMultiLine" android:minLines="3" android:maxLines="5" android:layout_marginBottom="16dp"/>
            <Button android:id="@+id/settingsSaveBtn" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="SAVE CONFIG" android:textColor="@color/black" android:background="@drawable/bg_btn_primary"
                android:fontFamily="monospace" android:textStyle="bold" android:layout_marginBottom="24dp"
                android:minHeight="48dp" android:textAllCaps="false"/>
            <TextView android:text="-- DATA MANAGEMENT --" android:textSize="11sp" android:textColor="@color/biohazard_red"
                android:fontFamily="monospace" android:textStyle="bold" android:letterSpacing="0.2" android:layout_marginBottom="12dp"/>
            <Button android:id="@+id/settingsClearChatBtn" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="CLEAR CHAT HISTORY" android:textColor="@color/biohazard_red"
                android:background="@drawable/bg_btn_danger" android:fontFamily="monospace"
                android:layout_marginBottom="8dp" android:minHeight="48dp" android:textAllCaps="false"/>
            <Button android:id="@+id/settingsClearNotesBtn" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="PURGE ALL LOGS" android:textColor="@color/biohazard_red"
                android:background="@drawable/bg_btn_danger" android:fontFamily="monospace"
                android:layout_marginBottom="24dp" android:minHeight="48dp" android:textAllCaps="false"/>
            <TextView android:id="@+id/settingsInfo" android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="@color/text_hint" android:fontFamily="monospace"
                android:lineSpacingExtra="4dp" android:paddingBottom="32dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
